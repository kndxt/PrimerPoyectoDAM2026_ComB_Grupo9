<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Ícono de éxito -->
        <ImageView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginTop="20dp"
            android:src="@drawable/tilde"
            android:layout_gravity="center"/>

        <!-- Título principal -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¡Pago Acreditado!"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:textStyle="bold"
            android:textColor="#008f39"
            android:textSize="24sp"/>

        <!-- Monto -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$50.000"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:textStyle="bold"
            android:textSize="32sp"
            android:textColor="#2C3E50"/>

        <!-- Sección "Detalles del Pago" -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"
            android:background="#F5F6F7"
            android:padding="12dp"
            android:text="DETALLES DEL PAGO"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2C3E50"
            android:gravity="center"/>

        <!-- Cliente -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:text="Cliente:"
                android:textSize="16sp"
                android:textColor="#666666"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvCliente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Matias Cortez"
                android:textSize="16sp"
                android:textColor="@color/black"/>
        </LinearLayout>

        <!-- Actividad -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:text="Actividad:"
                android:textSize="16sp"
                android:textColor="#666666"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvActividad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Actividad seleccionada"
                android:textSize="16sp"
                android:textColor="@color/black"/>
        </LinearLayout>

        <!-- Monto -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:text="Monto:"
                android:textSize="16sp"
                android:textColor="#666666"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvMonto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$50.000"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Método de Pago -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:text="Método:"
                android:textSize="16sp"
                android:textColor="#666666"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvMetodo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transferencia"
                android:textSize="16sp"
                android:textColor="@color/black"/>
        </LinearLayout>

        <!-- Fecha -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:text="Fecha:"
                android:textSize="16sp"
                android:textColor="#666666"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10/04/2026"
                android:textSize="16sp"
                android:textColor="@color/black"/>
        </LinearLayout>

        <!-- Próximo Vencimiento -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:text="Próx. Venc.:"
                android:textSize="16sp"
                android:textColor="#666666"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvVencimiento"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10/05/2026"
                android:textSize="16sp"
                android:textColor="@color/black"/>
        </LinearLayout>

        <!-- Línea divisoria -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:background="#E0E0E0" />

        <!-- Estado de pago (éxito) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estado de pago:"
                android:textColor="#666666"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  Success"
                android:textSize="18sp"
                android:textColor="#008f39"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Botón volver al menú -->
        <Button
            android:id="@+id/btnVolverMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:text="Volver al Menú"
            android:backgroundTint="@color/black"
            android:textColor="@color/white"
            android:textSize="16sp"/>

    </LinearLayout>

</ScrollView>